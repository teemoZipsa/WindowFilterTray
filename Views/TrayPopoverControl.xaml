<UserControl x:Class="WindowFilterTray.Views.TrayPopoverControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="336"
             Focusable="True"
             PreviewKeyDown="UserControl_PreviewKeyDown"
             FontFamily="Segoe UI, Malgun Gothic">
  <UserControl.Resources>
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PageBrush" Color="#FAFBFC" />
    <SolidColorBrush x:Key="StrokeBrush" Color="#E5E8ED" />
    <SolidColorBrush x:Key="StrokeStrongBrush" Color="#D4D9E1" />
    <SolidColorBrush x:Key="TextBrush" Color="#14171C" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#4B5260" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#7A8190" />
    <SolidColorBrush x:Key="AccentBrush" Color="#2F7DD3" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#EAF3FF" />
    <SolidColorBrush x:Key="AccentTextBrush" Color="#1E5FAA" />
    <SolidColorBrush x:Key="DangerBrush" Color="#C44538" />
    <SolidColorBrush x:Key="DangerSoftBrush" Color="#FFF0EE" />
    <SolidColorBrush x:Key="PausedBrush" Color="#B8860B" />
    <SolidColorBrush x:Key="PausedSoftBrush" Color="#FFF7D6" />
    <DropShadowEffect x:Key="PopoverShadow" BlurRadius="28" ShadowDepth="5" Opacity="0.18" Color="#0F1724" />

    <Style TargetType="{x:Type TextBlock}">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="MutedText" TargetType="{x:Type TextBlock}">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}" />
    </Style>

    <Style x:Key="ActionButton" TargetType="{x:Type Button}">
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource StrokeStrongBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="PrimaryActionButton" TargetType="{x:Type Button}" BasedOn="{StaticResource ActionButton}">
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="RecentButton" TargetType="{x:Type Button}">
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Margin" Value="0,0,0,6" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
  </UserControl.Resources>

  <Border Background="{StaticResource PageBrush}"
          BorderBrush="{StaticResource StrokeBrush}"
          BorderThickness="1"
          CornerRadius="12"
          Padding="14"
          Effect="{StaticResource PopoverShadow}">
    <StackPanel>
      <Grid Margin="0,0,0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock Text="불쑥창닫개" FontSize="18" FontWeight="Bold" />
          <TextBlock x:Name="StatusDescriptionText"
                     Style="{StaticResource MutedText}"
                     Margin="0,2,0,0" />
        </StackPanel>
        <Border x:Name="StatusBadge"
                Grid.Column="1"
                CornerRadius="12"
                Padding="9,4"
                VerticalAlignment="Top">
          <TextBlock x:Name="StatusText" FontSize="12" FontWeight="SemiBold" />
        </Border>
      </Grid>

      <Grid Margin="0,0,0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="8" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10">
          <StackPanel>
            <TextBlock Text="오늘 처리" Style="{StaticResource MutedText}" />
            <TextBlock x:Name="TodayCountText" FontSize="21" FontWeight="Bold" Margin="0,2,0,0" />
          </StackPanel>
        </Border>
        <Border Grid.Column="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10">
          <StackPanel>
            <TextBlock Text="활성 규칙" Style="{StaticResource MutedText}" />
            <TextBlock x:Name="ActiveRuleCountText" FontSize="21" FontWeight="Bold" Margin="0,2,0,0" />
          </StackPanel>
        </Border>
      </Grid>

      <UniformGrid Columns="2" Rows="3" Margin="0,0,0,12">
        <Button x:Name="OpenButton" Content="앱 열기" Style="{StaticResource PrimaryActionButton}" Margin="0,0,6,6" Click="OpenButton_Click" />
        <Button Content="창 고르기" Style="{StaticResource ActionButton}" Margin="6,0,0,6" Click="PickerButton_Click" />
        <Button Content="처리 기록" Style="{StaticResource ActionButton}" Margin="0,0,6,6" Click="LogsButton_Click" />
        <Button x:Name="PauseButton" Style="{StaticResource ActionButton}" Margin="6,0,0,6" Click="PauseButton_Click" />
        <Button Content="종료" Style="{StaticResource ActionButton}" Margin="0,0,6,0" Click="ExitButton_Click" />
      </UniformGrid>

      <Border Background="{StaticResource PanelBrush}"
              BorderBrush="{StaticResource StrokeBrush}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="10">
        <StackPanel>
          <TextBlock Text="최근 감지 창" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" />
          <ItemsControl x:Name="RecentItems">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Style="{StaticResource RecentButton}" Click="RecentButton_Click">
                  <StackPanel>
                    <TextBlock Text="{Binding Summary}" FontSize="12" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ProcessName}" Style="{StaticResource MutedText}" Margin="0,2,0,0" />
                  </StackPanel>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock x:Name="RecentEmptyText"
                     Text="최근 감지된 창이 없습니다."
                     Style="{StaticResource MutedText}"
                     Margin="0,2,0,0" />
        </StackPanel>
      </Border>
    </StackPanel>
  </Border>
</UserControl>
