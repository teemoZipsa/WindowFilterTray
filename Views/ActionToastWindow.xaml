<Window x:Class="WindowFilterTray.Views.ActionToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="390"
        Height="162"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        AllowsTransparency="True">
  <Window.Resources>
    <DropShadowEffect x:Key="ToastShadow" BlurRadius="32" ShadowDepth="4" Opacity="0.18" Color="#0F1724" />
    <Style x:Key="ToastButton" TargetType="{x:Type Button}">
      <Setter Property="Height" Value="30" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#D4D9E1" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#14171C" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Border Background="#FAFBFC"
          BorderBrush="#E5E8ED"
          BorderThickness="1"
          CornerRadius="12"
          Padding="14"
          Effect="{StaticResource ToastShadow}">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="34" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border x:Name="IconBadge"
              Width="26"
              Height="26"
              Background="#EAF3FF"
              CornerRadius="8"
              VerticalAlignment="Top">
        <TextBlock x:Name="IconText"
                   Text="✓"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontWeight="Bold"
                   Foreground="#1E5FAA" />
      </Border>

      <StackPanel Grid.Column="1">
        <DockPanel>
          <TextBlock Text="창 하나를 정리했어요"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="#14171C" />
          <Border x:Name="ActionBadge"
                  DockPanel.Dock="Right"
                  Background="#EAF3FF"
                  CornerRadius="10"
                  Padding="8,3"
                  Margin="8,0,0,0">
            <TextBlock x:Name="ActionText"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#1E5FAA" />
          </Border>
        </DockPanel>
        <TextBlock x:Name="DetailText"
                   Margin="0,6,0,0"
                   Foreground="#4B5260"
                   FontSize="12"
                   TextTrimming="CharacterEllipsis" />
      </StackPanel>

      <TextBlock x:Name="MetaText"
                 Grid.Row="1"
                 Grid.Column="1"
                 Margin="0,8,0,0"
                 FontSize="11"
                 FontFamily="Consolas"
                 Foreground="#7A8190"
                 TextTrimming="CharacterEllipsis" />

      <StackPanel Grid.Row="2"
                  Grid.ColumnSpan="2"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Margin="0,12,0,0">
        <Button x:Name="UndoButton"
                Content="되돌리기"
                Style="{StaticResource ToastButton}"
                Margin="0,0,8,0"
                Click="UndoButton_Click" />
        <Button x:Name="OpenLogButton"
                Content="기록 보기"
                Style="{StaticResource ToastButton}"
                Margin="0,0,8,0"
                Click="OpenLogButton_Click" />
        <Button x:Name="CloseButton"
                Content="닫기"
                Style="{StaticResource ToastButton}"
                Click="CloseButton_Click" />
      </StackPanel>
    </Grid>
  </Border>
</Window>
