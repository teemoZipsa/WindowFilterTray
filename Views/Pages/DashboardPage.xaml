<UserControl x:Class="WindowFilterTray.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FAFBFC"
             FontFamily="Segoe UI, Malgun Gothic">
  <UserControl.Resources>
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SunkenBrush" Color="#EEF0F3" />
    <SolidColorBrush x:Key="StrokeBrush" Color="#E5E8ED" />
    <SolidColorBrush x:Key="StrokeStrongBrush" Color="#D4D9E1" />
    <SolidColorBrush x:Key="TextBrush" Color="#14171C" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#4B5260" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#7A8190" />
    <SolidColorBrush x:Key="AccentBrush" Color="#2F7DD3" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#EAF3FF" />
    <SolidColorBrush x:Key="AccentTextBrush" Color="#1E5FAA" />
    <SolidColorBrush x:Key="DangerBrush" Color="#C44538" />
    <SolidColorBrush x:Key="DangerSoftBrush" Color="#FFF0EE" />
    <DropShadowEffect x:Key="PanelShadow" BlurRadius="14" ShadowDepth="1" Opacity="0.08" Color="#0F1724" />

    <Style TargetType="{x:Type TextBlock}">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style x:Key="EyebrowText" TargetType="{x:Type TextBlock}">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}" />
    </Style>
    <Style x:Key="MutedText" TargetType="{x:Type TextBlock}">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}" />
    </Style>
    <Style x:Key="Card" TargetType="{x:Type Border}">
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Effect" Value="{StaticResource PanelShadow}" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>
    <Style x:Key="PrimaryButton" TargetType="{x:Type Button}">
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style x:Key="SecondaryButton" TargetType="{x:Type Button}" BasedOn="{StaticResource PrimaryButton}">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource StrokeStrongBrush}" />
      <Setter Property="FontWeight" Value="Normal" />
    </Style>
    <Style x:Key="GhostButton" TargetType="{x:Type Button}" BasedOn="{StaticResource SecondaryButton}">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
    </Style>
    <Style x:Key="SearchBox" TargetType="{x:Type TextBox}">
      <Setter Property="Height" Value="28" />
      <Setter Property="Width" Value="190" />
      <Setter Property="Padding" Value="9,4" />
      <Setter Property="BorderBrush" Value="{StaticResource StrokeStrongBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style x:Key="ModernListView" TargetType="{x:Type ListView}">
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
    </Style>
    <Style x:Key="StrengthSliderStyle" TargetType="{x:Type Slider}">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Slider}">
            <Grid Background="Transparent" Height="28">
              <Track x:Name="PART_Track" VerticalAlignment="Center">
                <Track.DecreaseRepeatButton>
                  <RepeatButton Command="Slider.DecreaseLarge" Background="Transparent" BorderThickness="0" Opacity="0" />
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                  <RepeatButton Command="Slider.IncreaseLarge" Background="Transparent" BorderThickness="0" Opacity="0" />
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                  <Thumb Width="18" Height="18">
                    <Thumb.Template>
                      <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Background="#FFFFFF" BorderBrush="{StaticResource AccentBrush}" BorderThickness="2" CornerRadius="9" />
                      </ControlTemplate>
                    </Thumb.Template>
                  </Thumb>
                </Track.Thumb>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>

  <ScrollViewer x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="20">
      <Grid Margin="0,0,0,16">
        <StackPanel>
          <TextBlock Text="대시보드" FontSize="22" FontWeight="Bold" />
          <TextBlock Text="최근 화면에 떠오른 창과 지금 작동 중인 규칙을 한눈에 봅니다."
                     Style="{StaticResource MutedText}"
                     Margin="0,3,0,0" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Content="창 고르기" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="Picker_Click" />
          <Button Content="선택한 창 규칙 만들기" Style="{StaticResource PrimaryButton}" Click="CreateRuleFromRecent_Click" />
        </StackPanel>
      </Grid>

      <Grid Margin="0,0,0,14">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="1*" />
          <ColumnDefinition Width="1*" />
          <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>
        <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,10,0">
          <StackPanel>
            <TextBlock Text="정리 규칙" Style="{StaticResource EyebrowText}" />
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
              <TextBlock x:Name="RulesCountText" Text="0" FontSize="28" FontWeight="Bold" />
              <TextBlock Text="개 활성" Margin="8,12,0,0" Style="{StaticResource MutedText}" />
            </StackPanel>
            <TextBlock Text="필요한 규칙만 켜두면 더 조용하게 작동합니다." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,8,0,0" />
          </StackPanel>
        </Border>
        <Border Grid.Column="1" Style="{StaticResource Card}" Padding="16" Margin="0,0,10,0">
          <StackPanel>
            <TextBlock Text="최근 감지" Style="{StaticResource EyebrowText}" />
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
              <TextBlock x:Name="RecentCountText" Text="0" FontSize="28" FontWeight="Bold" />
              <TextBlock Text="개 창" Margin="8,12,0,0" Style="{StaticResource MutedText}" />
            </StackPanel>
            <TextBlock Text="목록에서 고르면 바로 정리 규칙을 만들 수 있습니다." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,8,0,0" />
          </StackPanel>
        </Border>
        <Border Grid.Column="2" Style="{StaticResource Card}" Padding="16">
          <StackPanel>
            <TextBlock Text="처리 기록" Style="{StaticResource EyebrowText}" />
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
              <TextBlock x:Name="LogCountText" Text="0" FontSize="28" FontWeight="Bold" />
              <TextBlock Text="건 저장" Margin="8,12,0,0" Style="{StaticResource MutedText}" />
            </StackPanel>
            <TextBlock Text="최근 500건을 보관해 규칙 동작을 확인합니다." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,8,0,0" />
          </StackPanel>
        </Border>
      </Grid>

      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="1.2*" />
          <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="330" />
          <RowDefinition Height="260" />
        </Grid.RowDefinitions>

        <Border x:Name="RulesSection" Style="{StaticResource Card}" Margin="0,0,10,10">
          <DockPanel>
            <Border DockPanel.Dock="Top" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,0,0,1" Padding="16,10">
              <Grid>
                <TextBlock Text="정리 규칙" FontWeight="SemiBold" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                  <TextBox x:Name="RulesSearchBox"
                           Style="{StaticResource SearchBox}"
                           ToolTip="규칙 검색"
                           TextChanged="RulesSearchBox_TextChanged"
                           PreviewKeyDown="SearchBox_PreviewKeyDown" />
                  <Button Content="지우기" Style="{StaticResource GhostButton}" Height="28" Padding="8,0" Margin="6,0,8,0" Click="ClearRulesSearch_Click" />
                  <Button Content="설정 바꾸기" Style="{StaticResource SecondaryButton}" Height="28" Padding="10,0" Margin="0,0,6,0" Click="EditRule_Click" />
                  <Button Content="삭제" Style="{StaticResource GhostButton}" Height="28" Padding="10,0" Foreground="{StaticResource DangerBrush}" Click="DeleteRule_Click" />
                </StackPanel>
              </Grid>
            </Border>
            <Grid>
              <ListView x:Name="RulesList" Style="{StaticResource ModernListView}">
                <ListView.ItemTemplate>
                  <DataTemplate>
                    <Grid Margin="8,6">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="120" />
                      </Grid.ColumnDefinitions>
                      <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                AutomationProperties.Name="{Binding DisplayName, StringFormat=규칙 활성: {0}}"
                                VerticalAlignment="Center"
                                Click="RuleEnabledCheckBox_Click" />
                      <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding DisplayBasis}" Style="{StaticResource MutedText}" Margin="0,3,0,0" />
                      </StackPanel>
                      <Border Grid.Column="2" Background="{StaticResource AccentSoftBrush}" CornerRadius="10" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayAction}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AccentTextBrush}" />
                      </Border>
                      <TextBlock Grid.Column="3" Text="{Binding FrequencyCap.MaxImpressions, StringFormat=처음 {0}회 보기}" Style="{StaticResource MutedText}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>
              <TextBlock x:Name="RulesEmptyText" TextWrapping="Wrap" Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24" />
            </Grid>
          </DockPanel>
        </Border>

        <Border x:Name="RecentSection" Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,0,10">
          <DockPanel>
            <Border DockPanel.Dock="Top" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,0,0,1" Padding="16,12">
              <Grid>
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="최근 감지된 창" FontWeight="SemiBold" />
                  <Ellipse Width="6" Height="6" Fill="#2F9A68" Margin="8,6,0,0" />
                </StackPanel>
                <TextBlock Text="실시간" HorizontalAlignment="Right" Style="{StaticResource MutedText}" />
              </Grid>
            </Border>
            <Grid>
              <ListView x:Name="RecentList" Style="{StaticResource ModernListView}">
                <ListView.ItemTemplate>
                  <DataTemplate>
                    <Grid Margin="8,6">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="74" />
                      </Grid.ColumnDefinitions>
                      <StackPanel>
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                        <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,3,0,0">
                          <Run Text="{Binding ProcessName}" />
                          <Run Text=" · " />
                          <Run Text="{Binding ClassName}" />
                        </TextBlock>
                      </StackPanel>
                      <TextBlock Grid.Column="1" Text="{Binding SeenAt, StringFormat=HH:mm:ss}" Style="{StaticResource MutedText}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>
              <TextBlock x:Name="RecentEmptyText" Text="최근에 열린 창이 여기에 표시됩니다." TextWrapping="Wrap" Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24" />
            </Grid>
          </DockPanel>
        </Border>

        <Border x:Name="LogsSection" Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource Card}">
          <DockPanel>
            <Border DockPanel.Dock="Top" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,0,0,1" Padding="16,10">
              <Grid>
                <TextBlock Text="처리 기록" FontWeight="SemiBold" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                  <TextBox x:Name="LogsSearchBox"
                           Style="{StaticResource SearchBox}"
                           ToolTip="처리 기록 검색"
                           TextChanged="LogsSearchBox_TextChanged"
                           PreviewKeyDown="SearchBox_PreviewKeyDown" />
                  <Button Content="지우기" Style="{StaticResource GhostButton}" Height="28" Padding="8,0" Margin="6,0,0,0" Click="ClearLogsSearch_Click" />
                </StackPanel>
              </Grid>
            </Border>
            <Grid>
              <ListView x:Name="LogList" Style="{StaticResource ModernListView}">
                <ListView.ItemTemplate>
                  <DataTemplate>
                    <Grid Margin="8,6">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72" />
                        <ColumnDefinition Width="1.5*" />
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="1.2*" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{Binding At, StringFormat=HH:mm:ss}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                      <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding WindowTitle}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding ProcessName}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,2,0,0" />
                      </StackPanel>
                      <TextBlock Grid.Column="2" Text="{Binding RuleName}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                      <Border Grid.Column="3" Background="{StaticResource SunkenBrush}" CornerRadius="10" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayAction}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" />
                      </Border>
                      <TextBlock Grid.Column="4" Text="{Binding Reason}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                    </Grid>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>
              <TextBlock x:Name="LogsEmptyText" Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Grid>
          </DockPanel>
        </Border>
      </Grid>

      <Border x:Name="SettingsSection" Style="{StaticResource Card}" Padding="16" Margin="0,4,0,0">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="440" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <StackPanel>
            <TextBlock Text="정리 강도" FontWeight="SemiBold" />
            <Grid Width="420" Height="54" HorizontalAlignment="Left" Margin="0,6,0,0">
              <Border Height="4" VerticalAlignment="Top" Margin="8,14,8,0" Background="{StaticResource SunkenBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="2" />
              <Border x:Name="ModeFillBar" Height="4" Width="0" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="8,14,0,0" Background="{StaticResource AccentBrush}" CornerRadius="2" />
              <Canvas Height="28" VerticalAlignment="Top" IsHitTestVisible="False">
                <Rectangle x:Name="ModeMarkerOff" Width="2" Height="12" Fill="#8B95A5" Canvas.Left="8" Canvas.Top="10" />
                <Rectangle x:Name="ModeMarkerLow" Width="2" Height="12" Fill="#8B95A5" Canvas.Left="142.67" Canvas.Top="10" />
                <Rectangle x:Name="ModeMarkerOptimal" Width="2" Height="12" Fill="#8B95A5" Canvas.Left="277.33" Canvas.Top="10" />
                <Rectangle x:Name="ModeMarkerStrong" Width="2" Height="12" Fill="#8B95A5" Canvas.Left="412" Canvas.Top="10" />
              </Canvas>
              <Slider x:Name="ModeSlider" Minimum="0" Maximum="3" TickFrequency="1" IsSnapToTickEnabled="True" Style="{StaticResource StrengthSliderStyle}" Width="420" VerticalAlignment="Top" ValueChanged="ModeSlider_ValueChanged" />
              <Canvas Height="24" VerticalAlignment="Bottom" IsHitTestVisible="False">
                <TextBlock x:Name="ModeLabelOff" Text="구경만" Width="70" TextAlignment="Center" Canvas.Left="-27" />
                <TextBlock x:Name="ModeLabelLow" Text="조심" Width="70" TextAlignment="Center" Canvas.Left="108" />
                <TextBlock x:Name="ModeLabelOptimal" Text="적당" Width="70" TextAlignment="Center" Canvas.Left="242" />
                <TextBlock x:Name="ModeLabelStrong" Text="적극" Width="70" TextAlignment="Center" Canvas.Left="377" />
              </Canvas>
            </Grid>
          </StackPanel>
          <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock x:Name="ModeDescriptionText" FontWeight="SemiBold" />
            <TextBlock Text="중요한 시스템 창은 항상 그대로 둡니다." Margin="0,6,0,0" Style="{StaticResource MutedText}" />
            <CheckBox x:Name="KnownPopupTemplatesCheckBox"
                      Content="적극 모드에서 알려진 반복 팝업 자동 숨기기"
                      Margin="0,12,0,0"
                      FontWeight="SemiBold"
                      Checked="KnownPopupTemplatesCheckBox_Changed"
                      Unchecked="KnownPopupTemplatesCheckBox_Changed" />
            <TextBlock Text="네이트온, 팟플레이어, 알집 계열 등은 앱 이름과 팝업성 제목이 함께 맞을 때만 숨깁니다."
                       Margin="24,4,0,0"
                       Style="{StaticResource MutedText}"
                       TextWrapping="Wrap" />
            <Border Background="{StaticResource DangerSoftBrush}" BorderBrush="#F2C8C3" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,12,0,0">
              <TextBlock Text="닫기는 되돌릴 수 없습니다. 처음에는 작게 내리기나 숨기기를 권장합니다." TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource DangerBrush}" />
            </Border>
          </StackPanel>
        </Grid>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
