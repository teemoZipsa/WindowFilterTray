<UserControl x:Class="WindowFilterTray.Views.Pages.RuleEditorPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="560"
             Background="#F4F5F7"
             FontFamily="Segoe UI, Malgun Gothic"
             PreviewKeyDown="UserControl_PreviewKeyDown">
  <UserControl.Resources>
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SunkenBrush" Color="#EEF0F3" />
    <SolidColorBrush x:Key="StrokeBrush" Color="#E5E8ED" />
    <SolidColorBrush x:Key="StrokeStrongBrush" Color="#D4D9E1" />
    <SolidColorBrush x:Key="TextBrush" Color="#14171C" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#4B5260" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#7A8190" />
    <SolidColorBrush x:Key="AccentBrush" Color="#2F7DD3" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#EAF3FF" />
    <SolidColorBrush x:Key="AccentTextBrush" Color="#1E5FAA" />
    <SolidColorBrush x:Key="DangerBrush" Color="#C44538" />
    <SolidColorBrush x:Key="DangerSoftBrush" Color="#FFF0EE" />
    <DropShadowEffect x:Key="PanelShadow" BlurRadius="14" ShadowDepth="1" Opacity="0.08" Color="#0F1724" />

    <Style TargetType="{x:Type TextBlock}">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="EyebrowText" TargetType="{x:Type TextBlock}">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}" />
    </Style>

    <Style x:Key="MutedText" TargetType="{x:Type TextBlock}">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}" />
    </Style>

    <Style x:Key="Card" TargetType="{x:Type Border}">
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Effect" Value="{StaticResource PanelShadow}" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="PrimaryButton" TargetType="{x:Type Button}">
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="{x:Type Button}" BasedOn="{StaticResource PrimaryButton}">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource StrokeStrongBrush}" />
      <Setter Property="FontWeight" Value="Normal" />
    </Style>

    <Style x:Key="InputTextBox" TargetType="{x:Type TextBox}">
      <Setter Property="Height" Value="30" />
      <Setter Property="Padding" Value="9,5" />
      <Setter Property="BorderBrush" Value="{StaticResource StrokeStrongBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="ActionRadio" TargetType="{x:Type RadioButton}">
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type RadioButton}">
            <Border x:Name="Root"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource StrokeStrongBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12"
                    MinHeight="74">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="34" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border x:Name="IconBox"
                        Width="28"
                        Height="28"
                        Background="{StaticResource SunkenBrush}"
                        CornerRadius="8"
                        VerticalAlignment="Top">
                  <TextBlock Text="{Binding Icon}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             FontWeight="Bold"
                             Foreground="{StaticResource TextSecondaryBrush}" />
                </Border>
                <StackPanel Grid.Column="1">
                  <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding Description}"
                             Style="{StaticResource MutedText}"
                             TextWrapping="Wrap"
                             Margin="0,3,0,0" />
                </StackPanel>
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                <Setter TargetName="Root" Property="BorderThickness" Value="2" />
                <Setter TargetName="IconBox" Property="Background" Value="{StaticResource PanelBrush}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="20">
      <Grid Margin="0,0,0,12">
        <StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="정리 규칙" Style="{StaticResource MutedText}" />
            <TextBlock Text="  /  " Style="{StaticResource MutedText}" />
            <TextBlock x:Name="BreadcrumbCurrentText" Text="새 규칙 만들기" FontSize="12" FontWeight="SemiBold" />
          </StackPanel>
          <TextBlock x:Name="PageTitleText" Text="새 규칙 만들기" FontSize="22" FontWeight="Bold" />
          <TextBlock x:Name="PageSubtitleText"
                     Text="감지된 창에서 시작하면 매칭 기준이 자동으로 채워집니다."
                     Style="{StaticResource MutedText}"
                     Margin="0,3,0,0" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
          <Button Content="취소"
                  Style="{StaticResource SecondaryButton}"
                  Margin="0,0,8,0"
                  Click="Cancel_Click" />
          <Button x:Name="SaveButton"
                  Content="규칙 저장"
                  Style="{StaticResource PrimaryButton}"
                  Click="Save_Click" />
        </StackPanel>
      </Grid>

      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <StackPanel Margin="0,0,12,0">
          <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,0,12">
            <StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <Border Width="22" Height="22" Background="{StaticResource AccentSoftBrush}" CornerRadius="6" Margin="0,0,10,0">
                  <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentTextBrush}" />
                </Border>
                <StackPanel>
                  <TextBlock Text="기본" FontSize="14" FontWeight="SemiBold" />
                  <TextBlock Text="규칙 이름과 기준 창을 확인합니다" Style="{StaticResource MutedText}" />
                </StackPanel>
              </StackPanel>

              <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="120" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="규칙 이름" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBox x:Name="DisplayNameBox"
                         Grid.Column="1"
                         Style="{StaticResource InputTextBox}"
                         TextChanged="EditorInput_Changed" />
              </Grid>

              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="120" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                  <TextBlock Text="기준 창" FontWeight="SemiBold" />
                  <TextBlock Text="자동 채움" Style="{StaticResource MutedText}" />
                </StackPanel>
                <Border Grid.Column="1"
                        Background="{StaticResource SunkenBrush}"
                        BorderBrush="{StaticResource StrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                      <TextBlock x:Name="CapturedTitleText" FontWeight="SemiBold" />
                      <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,3,0,0">
                        <Run x:Name="CapturedProcessRun" />
                        <Run Text=" · " />
                        <Run x:Name="CapturedClassRun" />
                        <Run Text=" · " />
                        <Run x:Name="CapturedRectRun" />
                      </TextBlock>
                    </StackPanel>
                    <TextBlock x:Name="ModeHintText"
                               Grid.Column="1"
                               Text="감지됨"
                               Style="{StaticResource MutedText}"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0" />
                  </Grid>
                </Border>
              </Grid>
            </StackPanel>
          </Border>

          <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,0,12">
            <StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <Border Width="22" Height="22" Background="{StaticResource AccentSoftBrush}" CornerRadius="6" Margin="0,0,10,0">
                  <TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentTextBrush}" />
                </Border>
                <StackPanel>
                  <TextBlock Text="이런 창에 적용" FontSize="14" FontWeight="SemiBold" />
                  <TextBlock Text="켜진 조건이 모두 일치할 때만 실행됩니다" Style="{StaticResource MutedText}" />
                </StackPanel>
              </StackPanel>

              <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="34" />
                  <ColumnDefinition Width="110" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="UseTitleCheckBox" VerticalAlignment="Center" Checked="EditorInput_Changed" Unchecked="EditorInput_Changed" />
                <StackPanel Grid.Column="1">
                  <TextBlock Text="제목" FontWeight="SemiBold" />
                  <TextBlock Text="고정 제목 팝업에 유용" Style="{StaticResource MutedText}" />
                </StackPanel>
                <TextBox x:Name="TitleContainsBox" Grid.Column="2" Style="{StaticResource InputTextBox}" TextChanged="EditorInput_Changed" />
              </Grid>

              <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="34" />
                  <ColumnDefinition Width="110" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="UseProcessCheckBox" VerticalAlignment="Center" Checked="EditorInput_Changed" Unchecked="EditorInput_Changed" />
                <StackPanel Grid.Column="1">
                  <TextBlock Text="앱" FontWeight="SemiBold" />
                  <TextBlock Text="프로세스명" Style="{StaticResource MutedText}" />
                </StackPanel>
                <TextBox x:Name="ProcessNameBox" Grid.Column="2" Style="{StaticResource InputTextBox}" FontFamily="Consolas" TextChanged="EditorInput_Changed" />
              </Grid>

              <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="34" />
                  <ColumnDefinition Width="110" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="UseClassCheckBox" VerticalAlignment="Center" Checked="EditorInput_Changed" Unchecked="EditorInput_Changed" />
                <StackPanel Grid.Column="1">
                  <TextBlock Text="창 클래스" FontWeight="SemiBold" />
                  <TextBlock Text="고급 조건" Style="{StaticResource MutedText}" />
                </StackPanel>
                <TextBox x:Name="WindowClassBox" Grid.Column="2" Style="{StaticResource InputTextBox}" FontFamily="Consolas" TextChanged="EditorInput_Changed" />
              </Grid>

              <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="34" />
                  <ColumnDefinition Width="110" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="UseSizeCheckBox" VerticalAlignment="Center" Checked="EditorInput_Changed" Unchecked="EditorInput_Changed" />
                <TextBlock Grid.Column="1" Text="크기" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock x:Name="SizeText" Grid.Column="2" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
              </Grid>

              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="34" />
                  <ColumnDefinition Width="110" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="UsePositionCheckBox" VerticalAlignment="Center" Checked="EditorInput_Changed" Unchecked="EditorInput_Changed" />
                <TextBlock Grid.Column="1" Text="위치" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock x:Name="PositionText" Grid.Column="2" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Style="{StaticResource Card}" Padding="18">
            <StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <Border Width="22" Height="22" Background="{StaticResource AccentSoftBrush}" CornerRadius="6" Margin="0,0,10,0">
                  <TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentTextBrush}" />
                </Border>
                <StackPanel>
                  <TextBlock Text="이렇게 처리하기" FontSize="14" FontWeight="SemiBold" />
                  <TextBlock Text="매칭되면 실행할 작업을 선택합니다" Style="{StaticResource MutedText}" />
                </StackPanel>
              </StackPanel>

              <ItemsControl x:Name="ActionItemsControl">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <UniformGrid Columns="2" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <RadioButton Style="{StaticResource ActionRadio}"
                                 GroupName="RuleAction"
                                 IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                 Margin="0,0,10,10"
                                 Checked="ActionRadio_Checked" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <Grid Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="150" />
                  <ColumnDefinition Width="120" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="처음 몇 번은 그냥 보기" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBox x:Name="MaxImpressionsBox"
                         Grid.Column="1"
                         Style="{StaticResource InputTextBox}"
                         TextChanged="EditorInput_Changed" />
                <TextBlock Grid.Column="2"
                           Text="0이면 처음부터 바로 처리합니다."
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0" />
              </Grid>

              <Border Background="{StaticResource DangerSoftBrush}"
                      BorderBrush="#F2C8C3"
                      BorderThickness="1"
                      CornerRadius="8"
                      Padding="10"
                      Margin="0,12,0,0">
                <TextBlock Text="닫기는 되돌릴 수 없습니다. 먼저 작게 내리기나 숨기기로 며칠 지켜본 뒤 사용하는 것을 권장합니다."
                           TextWrapping="Wrap"
                           FontSize="12"
                           Foreground="{StaticResource DangerBrush}" />
              </Border>
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="1">
          <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,0,12">
            <StackPanel>
              <TextBlock Text="미리보기" Style="{StaticResource EyebrowText}" />
              <TextBlock x:Name="PreviewNameText" FontSize="14" FontWeight="SemiBold" Margin="0,6,0,0" />
              <TextBlock Text="다음 조건이 모두 일치하면"
                         Style="{StaticResource MutedText}"
                         Margin="0,12,0,6" />
              <ItemsControl x:Name="ConditionChipsControl">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{StaticResource SunkenBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="7,3"
                            Margin="0,0,4,4">
                      <TextBlock FontSize="11" FontFamily="Consolas" Text="{Binding}" Foreground="{StaticResource TextSecondaryBrush}" />
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <Border Background="{StaticResource AccentSoftBrush}"
                      CornerRadius="10"
                      Padding="8,4"
                      HorizontalAlignment="Left"
                      Margin="0,10,0,0">
                <TextBlock x:Name="PreviewActionText" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AccentTextBrush}" />
              </Border>
              <TextBlock x:Name="PreviewFrequencyText"
                         Style="{StaticResource MutedText}"
                         TextWrapping="Wrap"
                         Margin="0,10,0,0" />
            </StackPanel>
          </Border>

          <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,0,12">
            <StackPanel>
              <TextBlock Text="기준 창 정보" Style="{StaticResource EyebrowText}" />
              <TextBlock x:Name="SummaryTitleText" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,6,0,6" />
              <TextBlock x:Name="SummaryProcessText" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" TextWrapping="Wrap" />
              <TextBlock x:Name="SummaryClassText" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" TextWrapping="Wrap" Margin="0,3,0,0" />
              <TextBlock x:Name="SummaryRectText" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,3,0,0" />
            </StackPanel>
          </Border>

          <Border Style="{StaticResource Card}" Padding="16">
            <StackPanel>
              <TextBlock Text="저장 상태" Style="{StaticResource EyebrowText}" />
              <TextBlock Text="저장 직후 규칙은 활성화됩니다."
                         Style="{StaticResource MutedText}"
                         TextWrapping="Wrap"
                         Margin="0,6,0,0" />
              <TextBlock x:Name="ValidationText"
                         TextWrapping="Wrap"
                         FontSize="12"
                         Foreground="{StaticResource DangerBrush}"
                         Margin="0,10,0,0" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
