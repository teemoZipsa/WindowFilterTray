<Window x:Class="WindowFilterTray.Views.RuleEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="정리 설정"
        Width="560"
        Height="640"
        MinWidth="520"
        MinHeight="560"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button Content="취소" Width="90" Margin="0,0,8,0" IsCancel="True" />
      <Button Content="저장" Width="100" IsDefault="True" Click="Save_Click" />
    </StackPanel>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <TextBlock Text="이름" FontWeight="SemiBold" />
        <TextBox x:Name="DisplayNameBox" Margin="0,4,0,12" />

        <GroupBox Header="기본 설정" Margin="0,0,0,12">
          <Grid Margin="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="160" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="처리 방법" VerticalAlignment="Center" />
            <ComboBox x:Name="ActionComboBox" Grid.Column="1" Margin="0,0,0,8" DisplayMemberPath="Label" />
            <TextBlock Text="처음 몇 번은 그냥 보기" Grid.Row="1" VerticalAlignment="Center" />
            <TextBox x:Name="MaxImpressionsBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" />
            <TextBlock Grid.Row="2"
                       Grid.ColumnSpan="2"
                       Text="닫기는 되돌릴 수 없습니다. 처음에는 작게 내리기를 권장합니다."
                       Foreground="#666"
                       TextWrapping="Wrap" />
          </Grid>
        </GroupBox>

        <Expander Header="고급 설정" IsExpanded="False" Margin="0,0,0,12">
          <StackPanel Margin="8">
            <GroupBox Header="고른 창 정보" Margin="0,0,0,12">
              <Grid Margin="8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="110" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="제목" FontWeight="SemiBold" />
                <TextBlock x:Name="CapturedTitleText" Grid.Column="1" TextWrapping="Wrap" />
                <TextBlock Text="앱" Grid.Row="1" FontWeight="SemiBold" />
                <TextBlock x:Name="CapturedProcessText" Grid.Row="1" Grid.Column="1" />
                <TextBlock Text="창 모양" Grid.Row="2" FontWeight="SemiBold" />
                <TextBlock x:Name="CapturedClassText" Grid.Row="2" Grid.Column="1" />
                <TextBlock Text="크기/위치" Grid.Row="3" FontWeight="SemiBold" />
                <TextBlock x:Name="CapturedRectText" Grid.Row="3" Grid.Column="1" />
              </Grid>
            </GroupBox>

            <CheckBox x:Name="UseProcessCheckBox" Content="앱 이름 사용 (권장)" Margin="0,0,0,6" />
            <TextBox x:Name="ProcessNameBox" Margin="20,0,0,10" />
            <CheckBox x:Name="UseClassCheckBox" Content="창 모양 사용" Margin="0,0,0,6" />
            <TextBox x:Name="WindowClassBox" Margin="20,0,0,10" />
            <CheckBox x:Name="UseTitleCheckBox" Content="창 제목 일부 사용" Margin="0,0,0,6" />
            <TextBox x:Name="TitleContainsBox" Margin="20,0,0,10" />
            <CheckBox x:Name="UseSizeCheckBox" Content="크기 사용" Margin="0,0,0,6" />
            <CheckBox x:Name="UsePositionCheckBox" Content="위치 사용" />
          </StackPanel>
        </Expander>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
