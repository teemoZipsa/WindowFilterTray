<Window x:Class="WindowFilterTray.Views.PickerOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="#22000000"
        Topmost="True"
        ShowInTaskbar="False"
        Cursor="Cross"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        KeyDown="Window_KeyDown">
  <Grid>
    <Border HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Margin="0,24,0,0"
            Background="#EE20242A"
            Padding="14,10"
            CornerRadius="6">
      <TextBlock Foreground="White"
                 FontWeight="SemiBold"
                 Text="규칙으로 등록할 창을 클릭하세요. 취소하려면 Esc를 누르세요." />
    </Border>
  </Grid>
</Window>
