<Window x:Class="WindowFilterTray.Views.PickerOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="#330F1724"
        Topmost="True"
        ShowInTaskbar="False"
        Cursor="Cross"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseMove="Window_MouseMove"
        KeyDown="Window_KeyDown">
  <Window.Resources>
    <DropShadowEffect x:Key="PanelShadow" BlurRadius="24" ShadowDepth="2" Opacity="0.22" Color="#0F1724" />
  </Window.Resources>

  <Canvas x:Name="OverlayCanvas">
    <Border x:Name="GuidePanel"
            Canvas.Top="24"
            Width="420"
            Background="#F8FFFFFF"
            BorderBrush="#E5E8ED"
            BorderThickness="1"
            CornerRadius="12"
            Padding="16,12"
            Effect="{StaticResource PanelShadow}">
      <StackPanel>
        <TextBlock Text="정리할 창을 선택하세요"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="#14171C" />
        <TextBlock Text="마우스를 올리면 대상 창을 강조합니다. 클릭해서 규칙을 만들고, Esc로 취소합니다."
                   Margin="0,4,0,0"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Foreground="#4B5260" />
      </StackPanel>
    </Border>

    <Border x:Name="HighlightBorder"
            Visibility="Collapsed"
            BorderBrush="#2F7DD3"
            BorderThickness="3"
            CornerRadius="7"
            Background="#182F7DD3"
            IsHitTestVisible="False" />

    <Border x:Name="InfoPanel"
            Visibility="Collapsed"
            Width="340"
            Background="#FAFBFC"
            BorderBrush="#D4D9E1"
            BorderThickness="1"
            CornerRadius="10"
            Padding="12"
            Effect="{StaticResource PanelShadow}"
            IsHitTestVisible="False">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="28" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Width="22"
                Height="22"
                Background="#EAF3FF"
                CornerRadius="6"
                VerticalAlignment="Top">
          <TextBlock Text="□"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontWeight="Bold"
                     Foreground="#1E5FAA" />
        </Border>
        <StackPanel Grid.Column="1">
          <TextBlock x:Name="InfoTitleText"
                     FontWeight="SemiBold"
                     FontSize="13"
                     Foreground="#14171C"
                     TextTrimming="CharacterEllipsis" />
          <TextBlock x:Name="InfoProcessText"
                     Margin="0,3,0,0"
                     FontFamily="Consolas"
                     FontSize="11"
                     Foreground="#7A8190"
                     TextTrimming="CharacterEllipsis" />
          <TextBlock x:Name="InfoClassText"
                     Margin="0,2,0,0"
                     FontFamily="Consolas"
                     FontSize="11"
                     Foreground="#7A8190"
                     TextTrimming="CharacterEllipsis" />
        </StackPanel>
      </Grid>
    </Border>
  </Canvas>
</Window>
