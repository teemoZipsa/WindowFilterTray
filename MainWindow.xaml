<Window x:Class="WindowFilterTray.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="불쑥창닫개"
        Width="980"
        Height="680"
        MinWidth="900"
        MinHeight="620"
        Background="#F4F5F7"
        FontFamily="Segoe UI, Malgun Gothic">
  <Window.Resources>
    <SolidColorBrush x:Key="AppBrush" Color="#FAFBFC" />
    <SolidColorBrush x:Key="SunkenBrush" Color="#EEF0F3" />
    <SolidColorBrush x:Key="StrokeBrush" Color="#E5E8ED" />
    <SolidColorBrush x:Key="TextBrush" Color="#14171C" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#4B5260" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#7A8190" />
    <SolidColorBrush x:Key="AccentBrush" Color="#2F7DD3" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#EAF3FF" />
    <SolidColorBrush x:Key="AccentTextBrush" Color="#1E5FAA" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#2F9A68" />
    <SolidColorBrush x:Key="WarningBrush" Color="#B8860B" />

    <Style TargetType="{x:Type TextBlock}">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="EyebrowText" TargetType="{x:Type TextBlock}">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}" />
    </Style>

    <Style x:Key="MutedText" TargetType="{x:Type TextBlock}">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}" />
    </Style>

    <Style x:Key="PrimaryButton" TargetType="{x:Type Button}">
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="GhostButton" TargetType="{x:Type Button}" BasedOn="{StaticResource PrimaryButton}">
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="FontWeight" Value="Normal" />
    </Style>

    <Style x:Key="NavButton" TargetType="{x:Type RadioButton}">
      <Setter Property="Height" Value="34" />
      <Setter Property="Margin" Value="0,1" />
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type RadioButton}">
            <Border x:Name="Root" Background="Transparent" CornerRadius="6" Padding="10,0">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="4" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border x:Name="Indicator" Width="3" Height="18" HorizontalAlignment="Left" VerticalAlignment="Center" Background="Transparent" CornerRadius="2" />
                <ContentPresenter Grid.Column="1" VerticalAlignment="Center" RecognizesAccessKey="True" />
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{StaticResource SunkenBrush}" />
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                <Setter TargetName="Indicator" Property="Background" Value="{StaticResource AccentBrush}" />
                <Setter Property="Foreground" Value="{StaticResource AccentTextBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Border Margin="14"
          Background="{StaticResource AppBrush}"
          BorderBrush="{StaticResource StrokeBrush}"
          BorderThickness="1"
          CornerRadius="14"
          ClipToBounds="True">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="36" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Border BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,0,0,1">
        <DockPanel LastChildFill="False">
          <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
            <Border Width="16" Height="16" Background="{StaticResource AccentBrush}" CornerRadius="4" Margin="0,0,8,0" />
            <TextBlock Text="불쑥창닫개" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" />
          </StackPanel>
          <Button DockPanel.Dock="Right" Width="44" Height="32" Content="X" Style="{StaticResource GhostButton}" Click="CloseButton_Click" />
        </DockPanel>
      </Border>

      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="200" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,0,1,0" Padding="8">
          <DockPanel>
            <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
              <TextBlock Text="상태" Style="{StaticResource EyebrowText}" Margin="10,8,10,6" />
              <Border Background="{StaticResource SunkenBrush}" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                <StackPanel>
                  <DockPanel>
                    <TextBlock Text="시스템 창 보호" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                    <Border DockPanel.Dock="Right" Width="28" Height="16" Background="{StaticResource AccentBrush}" CornerRadius="8">
                      <Ellipse Width="10" Height="10" Fill="White" HorizontalAlignment="Right" Margin="0,0,3,0" />
                    </Border>
                  </DockPanel>
                  <CheckBox x:Name="AutoStartCheckBox"
                            Content="Windows 시작 시 실행"
                            Margin="0,10,0,0"
                            FontSize="12"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Checked="AutoStartCheckBox_Changed"
                            Unchecked="AutoStartCheckBox_Changed" />
                </StackPanel>
              </Border>
            </StackPanel>

            <StackPanel>
              <TextBlock Text="탐색" Style="{StaticResource EyebrowText}" Margin="10,2,10,6" />
              <RadioButton x:Name="DashboardNavButton" Content="대시보드" Style="{StaticResource NavButton}" IsChecked="True" Checked="NavDashboard_Checked" />
              <RadioButton x:Name="RulesNavButton" Content="정리 규칙" Style="{StaticResource NavButton}" Checked="NavRules_Checked" />
              <RadioButton x:Name="RecentNavButton" Content="최근 감지 창" Style="{StaticResource NavButton}" Checked="NavRecent_Checked" />
              <RadioButton x:Name="LogsNavButton" Content="처리 기록" Style="{StaticResource NavButton}" Checked="NavLogs_Checked" />
              <RadioButton x:Name="SettingsNavButton" Content="설정" Style="{StaticResource NavButton}" Checked="NavSettings_Checked" />

              <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="10" Padding="12" Margin="0,18,0,0">
                <StackPanel>
                  <TextBlock Text="빠른 작업" FontWeight="SemiBold" Foreground="{StaticResource AccentTextBrush}" />
                  <TextBlock Text="불편한 창을 찍어서 바로 정리 규칙을 만들 수 있습니다."
                             TextWrapping="Wrap"
                             Margin="0,5,0,10"
                             FontSize="12"
                             Foreground="{StaticResource TextSecondaryBrush}" />
                  <Button Content="창 찍어서 규칙 만들기" Style="{StaticResource PrimaryButton}" Click="Picker_Click" />
                </StackPanel>
              </Border>
            </StackPanel>
          </DockPanel>
        </Border>

        <Grid Grid.Column="1">
          <Grid.RowDefinitions>
            <RowDefinition Height="76" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Border BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,0,0,1" Padding="20,12">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="150" />
              </Grid.ColumnDefinitions>

              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="{StaticResource SuccessBrush}" Margin="0,0,10,0" />
                <StackPanel>
                  <TextBlock Text="현재 상태" Style="{StaticResource EyebrowText}" />
                  <TextBlock x:Name="StatusValueText" Text="감시 중" FontSize="14" FontWeight="SemiBold" />
                </StackPanel>
              </StackPanel>
              <Border Grid.Column="1" Width="1" Height="28" Background="{StaticResource StrokeBrush}" VerticalAlignment="Center" />
              <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="18,0,0,0">
                <TextBlock Text="정리 강도" Style="{StaticResource EyebrowText}" />
                <Border Background="{StaticResource AccentSoftBrush}" BorderBrush="#D5E8FF" BorderThickness="1" CornerRadius="10" HorizontalAlignment="Left" Padding="8,3" Margin="0,2,0,0">
                  <TextBlock x:Name="StatusModeText" Text="적당" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentTextBrush}" />
                </Border>
              </StackPanel>
              <Border Grid.Column="3" Width="1" Height="28" Background="{StaticResource StrokeBrush}" VerticalAlignment="Center" />
              <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="18,0,0,0">
                <TextBlock Text="오늘 정리한 창" Style="{StaticResource EyebrowText}" />
                <StackPanel Orientation="Horizontal" VerticalAlignment="Baseline">
                  <TextBlock x:Name="TodayCleanedText" Text="0" FontSize="18" FontWeight="Bold" />
                  <TextBlock Text="개" Margin="4,4,0,0" Style="{StaticResource MutedText}" />
                </StackPanel>
              </StackPanel>
              <CheckBox x:Name="PauseCheckBox"
                        Grid.Column="6"
                        Content="빠른 일시정지"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        FontWeight="SemiBold"
                        Checked="PauseCheckBox_Changed"
                        Unchecked="PauseCheckBox_Changed" />
            </Grid>
          </Border>

          <ContentControl x:Name="PageHost" Grid.Row="1" />
        </Grid>
      </Grid>
    </Grid>
  </Border>
</Window>
