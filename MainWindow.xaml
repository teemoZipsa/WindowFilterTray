<Window x:Class="WindowFilterTray.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="불쑥창닫개"
        Width="980"
        Height="680"
        MinWidth="760"
        MinHeight="520">
  <Window.Resources>
    <Style x:Key="StrengthSliderStyle" TargetType="{x:Type Slider}">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Slider}">
            <Grid Background="Transparent" Height="28">
              <Track x:Name="PART_Track" VerticalAlignment="Center">
                <Track.DecreaseRepeatButton>
                  <RepeatButton Command="Slider.DecreaseLarge"
                                Background="Transparent"
                                BorderThickness="0"
                                Opacity="0" />
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                  <RepeatButton Command="Slider.IncreaseLarge"
                                Background="Transparent"
                                BorderThickness="0"
                                Opacity="0" />
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                  <Thumb Width="11" Height="20">
                    <Thumb.Template>
                      <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Background="#EEF2F8"
                                BorderBrush="#8B95A5"
                                BorderThickness="1"
                                CornerRadius="1" />
                      </ControlTemplate>
                    </Thumb.Template>
                  </Thumb>
                </Track.Thumb>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>
  <DockPanel Margin="16">
    <Border DockPanel.Dock="Top" BorderBrush="#D6D8DE" BorderThickness="0,0,0,1" Padding="0,0,0,14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="2*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock Text="정리 강도" FontSize="18" FontWeight="SemiBold" />
          <Grid Width="420" Height="54" HorizontalAlignment="Left" Margin="0,4,0,0">
            <Border Height="4"
                    VerticalAlignment="Top"
                    Margin="8,14,8,0"
                    Background="#D9DEE7"
                    CornerRadius="2" />
            <Border x:Name="ModeFillBar"
                    Height="4"
                    Width="0"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Left"
                    Margin="8,14,0,0"
                    Background="#2F7DD3"
                    CornerRadius="2" />
            <Canvas x:Name="ModeMarkerCanvas"
                    Height="28"
                    VerticalAlignment="Top"
                    IsHitTestVisible="False">
              <Rectangle x:Name="ModeMarkerOff" Width="2" Height="12" Fill="#8B95A5" Canvas.Left="8" Canvas.Top="10" />
              <Rectangle x:Name="ModeMarkerLow" Width="2" Height="12" Fill="#8B95A5" Canvas.Left="142.67" Canvas.Top="10" />
              <Rectangle x:Name="ModeMarkerOptimal" Width="2" Height="12" Fill="#8B95A5" Canvas.Left="277.33" Canvas.Top="10" />
              <Rectangle x:Name="ModeMarkerStrong" Width="2" Height="12" Fill="#8B95A5" Canvas.Left="412" Canvas.Top="10" />
            </Canvas>
            <Slider x:Name="ModeSlider"
                    Minimum="0"
                    Maximum="3"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True"
                    Style="{StaticResource StrengthSliderStyle}"
                    Width="420"
                    VerticalAlignment="Top"
                    ValueChanged="ModeSlider_ValueChanged" />
            <Canvas Height="24" VerticalAlignment="Bottom" IsHitTestVisible="False">
              <TextBlock x:Name="ModeLabelOff" Text="구경만" Width="70" TextAlignment="Center" Canvas.Left="-27" />
              <TextBlock x:Name="ModeLabelLow" Text="조심" Width="70" TextAlignment="Center" Canvas.Left="108" />
              <TextBlock x:Name="ModeLabelOptimal" Text="적당" Width="70" TextAlignment="Center" Canvas.Left="242" />
              <TextBlock x:Name="ModeLabelStrong" Text="적극" Width="70" TextAlignment="Center" Canvas.Left="377" />
            </Canvas>
          </Grid>
          <TextBlock x:Name="ModeDescriptionText" Margin="0,6,0,0" FontWeight="SemiBold" />
          <TextBlock Text="중요한 시스템 창은 항상 그대로 둡니다."
                     Margin="0,6,0,0"
                     Foreground="#555" />
        </StackPanel>
        <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
          <CheckBox x:Name="PauseCheckBox"
                    Content="잠시 멈춤"
                    Margin="0,0,0,8"
                    Checked="PauseCheckBox_Changed"
                    Unchecked="PauseCheckBox_Changed" />
          <CheckBox x:Name="AutoStartCheckBox"
                    Content="Windows 시작 시 실행"
                    Checked="AutoStartCheckBox_Changed"
                    Unchecked="AutoStartCheckBox_Changed" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Margin="0,14,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1.15*" />
        <ColumnDefinition Width="1*" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="180" />
      </Grid.RowDefinitions>

      <GroupBox Header="앞으로 정리할 창" Margin="0,0,10,10">
        <DockPanel Margin="8">
          <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="설정 바꾸기" Width="110" Margin="0,0,8,0" Click="EditRule_Click" />
            <Button Content="삭제" Width="80" Click="DeleteRule_Click" />
          </StackPanel>
          <Grid>
            <ListView x:Name="RulesList">
              <ListView.View>
                <GridView>
                  <GridViewColumn Header="이름" DisplayMemberBinding="{Binding DisplayName}" Width="210" />
                  <GridViewColumn Header="처리 방법" DisplayMemberBinding="{Binding DisplayAction}" Width="110" />
                  <GridViewColumn Header="기준" DisplayMemberBinding="{Binding DisplayBasis}" Width="170" />
                </GridView>
              </ListView.View>
            </ListView>
            <TextBlock x:Name="RulesEmptyText"
                       Text="아직 정리할 창이 없습니다. 불편한 창이 뜨면 &quot;창 고르기&quot;로 추가하세요."
                       TextWrapping="Wrap"
                       Foreground="#666"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="24" />
          </Grid>
        </DockPanel>
      </GroupBox>

      <GroupBox Header="최근 뜬 창" Grid.Column="1" Margin="0,0,0,10">
        <DockPanel Margin="8">
          <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="창 고르기" Width="90" Margin="0,0,8,0" Click="Picker_Click" />
            <Button Content="앞으로 이 창 정리하기" Width="170" Click="CreateRuleFromRecent_Click" />
          </StackPanel>
          <Grid>
            <ListView x:Name="RecentList">
              <ListView.View>
                <GridView>
                  <GridViewColumn Header="시간" DisplayMemberBinding="{Binding SeenAt}" Width="130" />
                  <GridViewColumn Header="창 이름" DisplayMemberBinding="{Binding Title}" Width="220" />
                  <GridViewColumn Header="앱" DisplayMemberBinding="{Binding ProcessName}" Width="120" />
                </GridView>
              </ListView.View>
            </ListView>
            <TextBlock x:Name="RecentEmptyText"
                       Text="최근에 열린 창이 여기에 표시됩니다. 목록에서 고른 뒤 &quot;앞으로 이 창 정리하기&quot;를 누르세요."
                       TextWrapping="Wrap"
                       Foreground="#666"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="24" />
          </Grid>
        </DockPanel>
      </GroupBox>

      <GroupBox Header="정리 기록" Grid.Row="1" Grid.ColumnSpan="2">
        <Grid Margin="8">
          <ListView x:Name="LogList">
            <ListView.View>
              <GridView>
                <GridViewColumn Header="시간" DisplayMemberBinding="{Binding At}" Width="130" />
                <GridViewColumn Header="이름" DisplayMemberBinding="{Binding RuleName}" Width="180" />
                <GridViewColumn Header="앱" DisplayMemberBinding="{Binding ProcessName}" Width="120" />
                <GridViewColumn Header="처리" DisplayMemberBinding="{Binding DisplayAction}" Width="90" />
                <GridViewColumn Header="설명" DisplayMemberBinding="{Binding Reason}" Width="300" />
              </GridView>
            </ListView.View>
          </ListView>
          <TextBlock x:Name="LogsEmptyText"
                     Text="정리한 기록이 아직 없습니다."
                     Foreground="#666"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
        </Grid>
      </GroupBox>
    </Grid>
  </DockPanel>
</Window>
